# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/


# Turborepo
.turbo/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local
.env

# typescript
*.tsbuildinfo

# testing
coverage/

# generated native folders
ios/
android/

# build artifacts
*.apk
*.aab
*.ipa

# Per-app Playwright test suites — track scripts + docs, ignore runtime + secrets
apps/*/.playwright/.env.test
apps/*/.playwright/profiles/
apps/*/.playwright/screenshots/
apps/*/.playwright/snapshots/
apps/*/.playwright/reports/
apps/*/.playwright/fixtures/

# `playwright-cli` skill auto-generated artifacts (per-cwd, unrelated to per-app suites above)
.playwright-cli/
**/.playwright-cli/

# Per-app Maestro suites — track flows + docs, ignore runtime + secrets
apps/*/.maestro/.env.test
apps/*/.maestro/screenshots/
apps/*/.maestro/snapshots/
apps/*/.maestro/reports/

# Defensive: stray top-level .maestro/ directories created when Maestro
# is invoked from the wrong cwd (takeScreenshot paths are cwd-relative).
/.maestro/
**/.maestro/screenshots/

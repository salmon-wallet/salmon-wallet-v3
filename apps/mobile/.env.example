# Salmon Wallet Mobile - Environment Configuration
# Copy to .env and configure for your environment
#
# Env file layering (dotenv convention):
#   .env              — base vars loaded for ALL modes (local defaults + shared keys)
#   .env.local        — machine-specific overrides, git-ignored
#   .env.production   — overrides loaded by `npx expo export` (sets EXPO_PUBLIC_SALMON_ENV=production)
#   .env.staging      — overrides for staging builds (use: EXPO_PUBLIC_SALMON_ENV=staging npx expo export)
#
# Priority: .env.local > .env.[mode] > .env
#
# NOTE: Expo only supports STATIC dot-notation access (process.env.EXPO_PUBLIC_*).
# Dynamic access like process.env[key] is NOT supported by babel-preset-expo.

# Environment: local | staging | production
EXPO_PUBLIC_SALMON_ENV=local

# API Configuration (override defaults)
# EXPO_PUBLIC_API_URL=http://localhost:3000
# EXPO_PUBLIC_STATIC_API_URL=https://d1fh2pwo7kzely.cloudfront.net

# Local Docker Development
# EXPO_PUBLIC_API_HOST=localhost
# EXPO_PUBLIC_API_PORT=3000

# Solana RPC (optional override)
# EXPO_PUBLIC_SOLANA_RPC_URL=

# Feature Flags
EXPO_PUBLIC_ENABLE_TESTNET=false

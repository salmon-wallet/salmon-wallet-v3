# Salmon Wallet Mobile - Environment Variables
# Copy this file to .env and fill in your values

# API Configuration
EXPO_PUBLIC_API_URL=https://api.salmonwallet.io
EXPO_PUBLIC_API_VERSION=v1

# Solana Configuration
EXPO_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
EXPO_PUBLIC_SOLANA_NETWORK=mainnet-beta
EXPO_PUBLIC_HELIUS_API_KEY=

# Bitcoin Configuration
EXPO_PUBLIC_BITCOIN_NETWORK=mainnet

# Feature Flags
EXPO_PUBLIC_ENABLE_TESTNET=false
EXPO_PUBLIC_ENABLE_DEVNET=false

# Analytics (optional)
EXPO_PUBLIC_MIXPANEL_TOKEN=
EXPO_PUBLIC_SENTRY_DSN=

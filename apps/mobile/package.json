{
  "name": "@salmon/mobile",
  "main": "./index.js",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint app hooks src --ext .ts,.tsx --ignore-pattern '**/*.js'",
    "test": "node --no-warnings ../../node_modules/jest/bin/jest.js --passWithNoTests",
    "test:watch": "node --no-warnings ../../node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --no-warnings ../../node_modules/jest/bin/jest.js --coverage",
    "eas-build-post-install": "test \"$EAS_BUILD_PLATFORM\" = \"android\" && echo 'org.gradle.jvmargs=-Xmx4g -XX:MaxMetaspaceSize=1g' >> ./android/gradle.properties || true"
  },
  "expo": {
    "install": {
      "exclude": [
        "@react-navigation/native",
        "react-native-worklets"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-encrypted-storage",
          "react-native-fast-crypto",
          "react-native-vector-icons"
        ]
      }
    }
  },
  "dependencies": {
    "@expo/dom-webview": "55.0.5",
    "@expo/metro-runtime": "55.0.10",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.10.1",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.10.1",
    "@salmon/assets": "workspace:*",
    "@salmon/shared": "workspace:*",
    "buffer": "^6.0.3",
    "expo": "~55.0.16",
    "expo-blur": "~55.0.14",
    "expo-camera": "~55.0.16",
    "expo-clipboard": "~55.0.13",
    "expo-constants": "~55.0.15",
    "expo-crypto": "~55.0.14",
    "expo-dev-client": "^55.0.28",
    "expo-font": "~55.0.6",
    "expo-glass-effect": "~55.0.10",
    "expo-haptics": "^55.0.14",
    "expo-image": "^55.0.9",
    "expo-linear-gradient": "^55.0.13",
    "expo-linking": "~55.0.14",
    "expo-local-authentication": "~55.0.13",
    "expo-localization": "^55.0.13",
    "expo-router": "~55.0.13",
    "expo-secure-store": "~55.0.13",
    "expo-splash-screen": "~55.0.19",
    "expo-status-bar": "~55.0.5",
    "expo-system-ui": "^55.0.16",
    "expo-updates": "~55.0.21",
    "expo-web-browser": "~55.0.14",
    "i18next": "^25.6.2",
    "qrcode.react": "^4.2.0",
    "react": "19.2.0",
    "react-content-loader": "^7.1.1",
    "react-dom": "19.2.0",
    "react-i18next": "^16.3.3",
    "react-idle-timer": "^5.7.2",
    "react-native": "0.83.6",
    "react-native-encrypted-storage": "^4.0.3",
    "react-native-fast-crypto": "^3.0.0",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-get-random-values": "^1.11.0",
    "react-native-paper": "^5.14.5",
    "react-native-permissions": "^5.4.4",
    "react-native-qrcode-svg": "^6.3.20",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "~15.15.3",
    "react-native-toast-message": "^2.3.3",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.4",
    "readable-stream": "^4.5.2"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.14",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.16",
    "typescript": "~5.9.2"
  }
}

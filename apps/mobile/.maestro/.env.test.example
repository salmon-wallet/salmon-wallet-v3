# Salmon Maestro test secrets — example file.
# Copy to .env.test (gitignored) and fill with real values before running
# any flow in .maestro/flows/.
#
# Maestro reads these via `--env KEY=value` or by sourcing the file before
# `maestro test`. Phase 2 flows reference all four variables.

# Password used for both wallets during recovery + unlock.
SALMON_TEST_PASSWORD=CHANGE_ME_PLACEHOLDER

# Wallet A — primary test wallet. Sender in Send/Swap state-modifying flows.
# Needs a small mainnet SOL balance (Send moves 0.001 SOL on chain).
SALMON_TEST_SEED_A=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

# Wallet B — secondary wallet. Holds the Salmon Logo NFT used by the
# NFT transfer flow and is the recipient for cross-wallet Send tests.
SALMON_TEST_SEED_B=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

# Wallet B Solana address (derived from SALMON_TEST_SEED_B).
# Used as the recipient in send-sol.yaml and address-book-save.yaml.
SALMON_TEST_WALLET_B_ADDR=ReplaceWithWalletBSolanaAddress

# Wallet A Solana address (derived from SALMON_TEST_SEED_A).
# Used as the recipient in nft-transfer.yaml when sending from Wallet B.
SALMON_TEST_WALLET_A_ADDR=ReplaceWithWalletASolanaAddress

# Local fixture server for Solana Actions / Blinks e2e flows under
# flows/actions/blinks/. Serves canned Action GET/POST responses
# (happy path, simulator-reject, v0 feePayer mismatch). The simplest
# setup is `python3 -m http.server` over a static fixtures directory.
# See flows/actions/blinks/README.md.
BLINKS_FIXTURE_URL=http://localhost:8080

# Salmon Wallet Extension - Environment Configuration
# Copy to .env and configure for your environment
#
# Env file layering (Vite convention):
#   .env              — base vars loaded for ALL modes (local defaults + shared keys)
#   .env.production   — overrides loaded by `wxt build` (sets VITE_SALMON_ENV=production)
#   .env.staging      — overrides loaded by `wxt build --mode staging` (sets VITE_SALMON_ENV=staging)
#   .env.development  — overrides loaded by `wxt` dev server (optional)
#
# Priority: .env.[mode] overrides .env

# Environment: local | staging | production
VITE_SALMON_ENV=local

# API Configuration (override defaults)
# VITE_API_URL=http://localhost:3000
# VITE_STATIC_API_URL=https://d1fh2pwo7kzely.cloudfront.net

# Local Docker Development
# VITE_API_HOST=localhost
# VITE_API_PORT=3000

# Helius API Key for DAS API (NFTs, compressed assets)
# Get your key at https://dev.helius.xyz/
VITE_HELIUS_API_KEY=

# Feature Flags
VITE_ENABLE_TESTNET=false
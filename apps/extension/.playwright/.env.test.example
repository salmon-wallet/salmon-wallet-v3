# Salmon Playwright test secrets — example file.
# Copy to .env.test (gitignored) and fill with real values before running
# any script in .playwright/scripts/.
#
# loadSecrets() in scripts/lib.mjs throws on startup if any of these are
# unset, so partial files are not allowed.

# Password used for both wallets during recovery + unlock. Anything
# satisfying Salmon's password rules is fine; reuse for both seeds keeps
# the scripts simple.
SALMON_TEST_PASSWORD=CHANGE_ME_PLACEHOLDER

# Wallet A — primary test wallet. Used by default in lib.mjs/unlockOrRecover
# (onboarding path) and as the sender in state-modifying scripts.
# Choose a wallet you control with a small mainnet balance — Send tests
# move 0.001 SOL on chain.
SALMON_TEST_SEED_A=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

# Wallet B — secondary wallet. Used by:
#   - discover-wallet-addr.mjs to derive the recipient address for cross-
#     wallet sends. The output is written to fixtures/wallet-b-addr.txt.
#   - nft-spam-filter.mjs which expects this wallet to hold scam cNFTs
#     (otherwise the test still runs but reports an empty diff).
SALMON_TEST_SEED_B=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

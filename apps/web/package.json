{
  "name": "@salmon/web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:staging": "tsc --noEmit && vite build --mode staging",
    "build:prod": "tsc --noEmit && vite build --mode production",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lh": "lhci autorun",
    "e2e": "playwright test -c .playwright/playwright.config.ts",
    "e2e:ui": "playwright test -c .playwright/playwright.config.ts --ui"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^7.3.7",
    "@mui/material": "^7.3.5",
    "@salmon/shared": "workspace:*",
    "@salmon/ui": "workspace:*",
    "bs58": "^6.0.0",
    "buffer": "^6.0.3",
    "i18next": "^25.6.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "process": "^0.11.10",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^16.3.3",
    "react-router-dom": "^7.9.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@types/react": "~19.1.0",
    "@types/react-dom": "~19.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "~5.9.2",
    "vite": "^7.3.1"
  }
}

# Production build inputs for the web app.
#
# Committed on purpose (no secrets): Vite bakes VITE_* vars into the client
# bundle, so they are public by definition. Required so `build:prod` resolves
# the AWS prod API from a clean CI checkout (deploy-web workflow) instead of
# falling back to localhost.
VITE_SALMON_ENV=production
VITE_API_URL=https://te4x28v8e0.execute-api.us-east-1.amazonaws.com/prod
VITE_STATIC_API_URL=https://d1fh2pwo7kzely.cloudfront.net

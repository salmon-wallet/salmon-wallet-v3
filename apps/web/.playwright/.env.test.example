# Salmon Web Playwright test secrets — example file.
# Copy to .env.test (gitignored) and fill before running authenticated web e2e.
#
# Mirrors the extension suite's contract: the helpers in helpers.ts unlock an
# existing wallet or recover SEED_A on a fresh profile, so the password and at
# least SEED_A are required for any spec that needs to reach home (e.g.
# responsive.spec.ts). The boot-only specs (smoke, a11y) run without secrets.

# Wallet password (the app requires 12+ chars).
SALMON_TEST_PASSWORD=CHANGE_ME_PLACEHOLDER

# Recovery phrase used to seed the test wallet (Wallet A).
SALMON_TEST_SEED_A=word1 word2 ... word12

# Optional second wallet, for flows that need a counterparty address.
SALMON_TEST_SEED_B=word1 word2 ... word12
